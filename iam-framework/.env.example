# Copy this to .env and fill in your values
# Never commit the actual .env file

AWS_DEFAULT_REGION=us-east-1
AWS_PROFILE=default

# CloudWatch log group for audit decisions
CW_LOG_GROUP=/iam-framework/access-decisions

# S3 bucket to store audit logs for Athena querying
S3_AUDIT_BUCKET=

# Local directory for audit log files
AUDIT_LOG_DIR=./audit_logs
